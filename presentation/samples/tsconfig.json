{
  "$schema": "http://json.schemastore.org/tsconfig",
  // Standalone project for presentation code samples.
  // It is intentionally NOT referenced by the SPFx build (the build's tsconfig
  // only includes src/**), so nothing here is ever compiled, bundled, or shipped.
  // Its only job is to give VS Code IntelliSense + ESLint real type information
  // so you can confirm the snippets are valid.
  "compilerOptions": {
    "jsx": "react",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "es2017"],
    // Resolve react / @types/react from the repo root node_modules.
    "baseUrl": ".",
    "typeRoots": ["../../node_modules/@types"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
